# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — API 키, 시크릿 등 민감 정보
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
# 예외: 예시 파일은 커밋 허용
!.env.example

# supabase 로컬 설정 (서비스 키 포함 가능)
supabase/.temp/
supabase/config.toml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code
.claude/

# macOS
.DS_Store
